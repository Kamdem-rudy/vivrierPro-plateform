# ═══════════════════════════════════════════════════════════════════
# VARIABLES D'ENVIRONNEMENT — VivriérPro
# ═══════════════════════════════════════════════════════════════════
# Copier ce fichier en .env.local pour le développement local
# Ajouter ces variables dans Vercel → Settings → Environment Variables

# ── Supabase : Pooler PgBouncer (pour l'application) ──────────────
# Project Settings → Database → Connection pooling
# Mode Transaction | Port 6543
DATABASE_URL="postgresql://postgres.VOTRE_REF:VOTRE_MDP@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# ── Supabase : Connexion directe (pour prisma db push) ─────────────
# Project Settings → Database → Connection string
# Port 5432
DIRECT_URL="postgresql://postgres.VOTRE_REF:VOTRE_MDP@aws-0-REGION.supabase.com:5432/postgres"

# ── NextAuth ───────────────────────────────────────────────────────
# Générer un secret : openssl rand -base64 32
NEXTAUTH_SECRET="REMPLACEZ-PAR-UN-SECRET-FORT-GENERE-AVEC-OPENSSL"

# En développement local :
NEXTAUTH_URL="http://localhost:3000"
# Sur Vercel : mettre l'URL exacte de votre app
# NEXTAUTH_URL="https://votre-app.vercel.app"
# Note : Sur Vercel, NEXTAUTH_URL est souvent auto-détecté via VERCEL_URL
